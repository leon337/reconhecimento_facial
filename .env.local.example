# Copie para .env.local e substitua todos os valores CHANGE_ME.
APP_ENV=pilot
SECRET_KEY=CHANGE_ME_LONG_RANDOM_SECRET
BIOMETRIC_ENCRYPTION_KEY=CHANGE_ME_FERNET_KEY

POSTGRES_DB=controle_ponto_piloto
POSTGRES_USER=controle_ponto
POSTGRES_PASSWORD=CHANGE_ME_DATABASE_PASSWORD

PILOT_COMPANY_NAME=Potiguar
PILOT_COMPANY_SLUG=potiguar
PILOT_WORKSITE_NAME=Obra Piloto
